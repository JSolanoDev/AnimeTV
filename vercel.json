{
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "dist",
  "functions": {
    "animetv-local.js": {
      "maxDuration": 30,
      "includeFiles": "{index.html,offline.html,styles.css,client.js,js/**,update-manager.js,manifest.webmanifest,sources.json,icon.svg,service-worker.js,animetv-settings.json}"
    },
    "api/**/*.js": {
      "maxDuration": 30,
      "includeFiles": "{index.html,offline.html,styles.css,client.js,js/**,update-manager.js,manifest.webmanifest,sources.json,icon.svg,service-worker.js,animetv-settings.json}"
    }
  },
  "headers": [
    {
      "source": "/(.*).(js|css|svg|webmanifest)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, stale-while-revalidate=300"
        }
      ]
    }
  ]
}
